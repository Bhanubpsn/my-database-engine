# Locate Homebrew paths (Standard on Apple Silicon Macs)
HOMEBREW_PREFIX = /opt/homebrew
LDFLAGS = -L$(HOMEBREW_PREFIX)/lib `pkg-config --libs protobuf grpc++`
CPPFLAGS = -I$(HOMEBREW_PREFIX)/include -I. `pkg-config --cflags protobuf grpc++` -std=c++17

# The final binary name
TARGET = db_engine

# The object files needed
OBJS = database.pb.o database.grpc.pb.o main.o

all: $(TARGET)

$(TARGET): $(OBJS)
	clang++ $(OBJS) $(LDFLAGS) -o $(TARGET)

# Rule for .cc files (generated by protoc)
%.o: %.cc
	clang++ $(CPPFLAGS) -c $< -o $@

# Rule for .cpp files (your main.cpp)
%.o: %.cpp
	clang++ $(CPPFLAGS) -c $< -o $@

clean:
	rm -f *.o $(TARGET)
